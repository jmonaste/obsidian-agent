# Copy to .env and fill in. Never commit the real .env.

# --- Company LLM (OpenAI-compatible endpoint) ---
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=not-needed
OBSIDIAN_MODEL=gpt-oss

# --- Vault ---
OBSIDIAN_VAULT_PATH=/absolute/path/to/CompanyVault

# --- Agent loop ---
AGENT_MAX_ITERATIONS=12
AGENT_TEMPERATURE=0
